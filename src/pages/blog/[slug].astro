---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
export async function getStaticPaths() {
  const posts = (await getCollection("posts")).filter(p=>!p.data.draft);
  return posts.map(p=>({ params:{ slug:p.id }, props:{ post:p } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} — ChaiKlang`} description={post.data.summary}>
  <header class="wrap" style="padding:1.1rem 1.25rem"><a href="/blog" style="color:var(--muted)">← Blog</a></header>
  <article class="wrap" style="padding:2.5rem 1.25rem;max-width:720px">
    <h1 style="font-size:clamp(1.8rem,4.5vw,2.6rem);margin:0">{post.data.title}</h1>
    <p style="color:var(--muted);margin:.5rem 0 1.5rem">{post.data.date} · {post.data.tags.map(t=>`#${t}`).join(" ")}</p>
    <div style="font-size:1.08rem;line-height:1.75;color:var(--fg)"><Content /></div>
    <p style="margin-top:2.5rem"><a href="/blog">← more posts</a></p>
  </article>
</Base>
