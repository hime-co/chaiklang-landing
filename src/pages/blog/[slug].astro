---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
export async function getStaticPaths(){
  const posts=(await getCollection("posts")).filter(p=>!p.data.draft);
  return posts.map(p=>({params:{slug:p.id},props:{post:p}}));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} — ChaiKlang`} description={post.data.summary}>
  <header class="wrap" style="padding:var(--s4) var(--s6)"><a href="/blog" style="color:var(--muted);font-weight:500">← Blog</a></header>
  <article class="wrap" style="padding:var(--s12) var(--s6);max-width:680px">
    <p class="eyebrow">{post.data.date}{post.data.workshop && ` · ${post.data.workshop}`} · {post.data.tags.map(t=>`#${t}`).join(" ")}</p>
    <h1 style="font-size:clamp(1.9rem,4.5vw,2.8rem);margin:var(--s3) 0 var(--s8)">{post.data.title}</h1>
    <div style="font-size:1.1rem;line-height:1.75;color:var(--fg)"><Content /></div>
    <p style="margin-top:var(--s12)"><a href="/blog" style="font-weight:500">← more posts</a></p>
  </article>
</Base>
